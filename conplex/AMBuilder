import os

project = builder.LibraryProject('conplex.ext')
project.sources += [
  'extension.cpp',
  os.path.join(Webcon.sm_root, 'public', 'smsdk_ext.cpp'),
]

for sdk in Webcon.sdks.values():
  for cxx in Webcon.all_targets:
    binary = project.Configure(cxx, 'conplex.ext',
                               '{0} - {1} - {2}'.format(Webcon.tag, sdk.name, cxx.target.arch))
    Webcon.ConfigureForExtension(builder, binary.compiler)
    # Pulls in the engine ConVar machinery (convar.h / tier1). The real tier1
    # headers replace conplex's vendored valve/ copies, which would otherwise
    # double-define CUtlVector et al.
    Webcon.ConfigureForHL2(builder, binary, sdk)
    Webcon.AddCDetour(binary)

    binary.compiler.defines += ['SOURCEMOD_BUILD']

    if binary.compiler.target.platform == 'windows':
      binary.compiler.linkflags += ['ws2_32.lib']

Webcon.extensions += builder.Add(project)
